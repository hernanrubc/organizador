.app { display: flex; height: 100vh; }

/* SIDEBAR */
.sidebar { width: 200px; min-width: 200px; background: var(--surface); border-right: 0.5px solid var(--border); display: flex; flex-direction: column; padding: 20px 0 12px; }
.sidebar-header { padding: 0 16px 16px; border-bottom: 0.5px solid var(--border); }
.day-name { font-size: 20px; font-weight: 500; color: var(--text); letter-spacing: -0.02em; }
.day-date { font-size: 12px; color: var(--muted); margin-top: 3px; }
.progress-wrap { padding: 14px 16px; border-bottom: 0.5px solid var(--border); }
.progress-nums { display: flex; justify-content: space-between; font-size: 11px; color: var(--muted); margin-bottom: 7px; }
.pbar { height: 2px; background: var(--border2); border-radius: 2px; }
.pfill { height: 100%; background: var(--accent); border-radius: 2px; transition: width 0.4s; }
.sidebar-section { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); padding: 14px 16px 6px; }
.cat-list { padding: 0 8px; }
.cat-item { display: flex; align-items: center; gap: 8px; padding: 6px 8px; border-radius: 6px; cursor: pointer; font-size: 13px; color: var(--muted); transition: all 0.15s; }
.cat-item:hover, .cat-item.active { background: var(--surface2); color: var(--text); }
.cat-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.cat-count { margin-left: auto; font-size: 11px; color: var(--muted); }
.sb-btn { margin: 4px 8px 0; display: flex; align-items: center; gap: 7px; padding: 5px 8px; border-radius: 6px; font-size: 12px; color: var(--muted); cursor: pointer; background: none; border: none; font-family: inherit; width: calc(100% - 16px); transition: all 0.15s; text-align: left; }
.sb-btn:hover { color: var(--text); background: var(--surface2); }
.people-list { padding: 0 8px; max-height: 110px; overflow-y: auto; }
.person-item { display: flex; align-items: center; gap: 7px; padding: 5px 8px; border-radius: 6px; font-size: 12px; color: var(--muted); cursor: context-menu; }
.person-item:hover { background: var(--surface2); color: var(--text); }
.p-avatar { width: 18px; height: 18px; border-radius: 50%; background: var(--surface3); display: flex; align-items: center; justify-content: center; font-size: 8px; font-weight: 600; flex-shrink: 0; color: var(--accent); }
.export-btn { margin: auto 8px 0; display: flex; align-items: center; justify-content: center; gap: 6px; padding: 8px; border-radius: 6px; font-size: 12px; color: var(--accent); cursor: pointer; background: var(--accent2); border: 0.5px solid rgba(201,169,110,0.2); font-family: inherit; width: calc(100% - 16px); transition: all 0.15s; }
.export-btn:hover { background: rgba(201,169,110,0.18); }

/* MAIN */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; background: var(--bg); }
.main-header { padding: 18px 24px 12px; border-bottom: 0.5px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.main-title { font-size: 15px; font-weight: 500; color: var(--text); }
.filter-row { display: flex; gap: 4px; }
.filter-btn { background: transparent; border: 0.5px solid var(--border); color: var(--muted); border-radius: 5px; padding: 4px 10px; font-size: 11px; cursor: pointer; font-family: inherit; transition: all 0.15s; }
.filter-btn:hover { color: var(--text); border-color: var(--border2); }
.filter-btn.active { color: var(--accent); border-color: rgba(201,169,110,0.3); background: var(--accent2); }
.task-area { flex: 1; overflow-y: auto; padding: 8px 16px 8px; }

/* PRIORITY GROUPS */
.priority-group { margin-bottom: 6px; }
.priority-label { display: flex; align-items: center; gap: 7px; padding: 8px 8px 4px; font-size: 10px; letter-spacing: 0.09em; text-transform: uppercase; color: var(--muted); cursor: pointer; user-select: none; }
.priority-label:hover { color: var(--text); }
.p-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.p-dot.p1 { background: var(--p1); } .p-dot.p2 { background: var(--p2); } .p-dot.p3 { background: var(--p3); } .p-dot.p4 { background: var(--p4); }
.group-toggle { margin-left: auto; font-size: 10px; transition: transform 0.2s; }
.priority-group.collapsed .group-toggle { transform: rotate(-90deg); }
.priority-group.collapsed .group-tasks { display: none; }

/* TASKS */
.task-item { display: flex; align-items: center; gap: 6px; padding: 6px 8px; border-radius: 7px; transition: background 0.12s; margin-bottom: 1px; cursor: default; }
.task-item:hover { background: var(--surface2); }
.task-item.done .task-text { text-decoration: line-through; color: var(--muted); }
.task-check { width: 15px; height: 15px; min-width: 15px; border-radius: 50%; border: 1.5px solid var(--border2); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.18s; flex-shrink: 0; }
.task-item.done .task-check { background: var(--done-color); border-color: var(--done-color); }
.chk { display: none; } .task-item.done .chk { display: block; }
.task-text { font-size: 13px; color: var(--text); line-height: 1.4; flex: 1; cursor: text; min-width: 0; }
.task-text-input { font-size: 13px; color: var(--text); line-height: 1.4; flex: 1; background: transparent; border: none; outline: none; font-family: inherit; padding: 0; min-width: 0; width: 100%; }
.task-sel { font-size: 11px; border-radius: 3px; cursor: pointer; flex-shrink: 0; border: none; outline: none; font-family: inherit; padding: 2px 5px; opacity: 0; transition: opacity 0.15s; -webkit-appearance: none; appearance: none; max-width: 76px; }
.task-item:hover .task-sel { opacity: 1; }
.task-sel option { background: #1a1a19; color: var(--text); }
.task-delete { font-size: 13px; color: var(--muted); background: none; border: none; cursor: pointer; padding: 0; opacity: 0; transition: opacity 0.15s, color 0.15s; flex-shrink: 0; line-height: 1; }
.task-item:hover .task-delete { opacity: 1; }
.task-delete:hover { color: var(--p1); }

