_1779216213490',owner:'p_1779214823103'}];
data.tasks.forEach(t=>{if(!('owner' in t))t.owner='';});
if(!data.cats) data.cats=[{id:'work',label:'Trabajo',color:'#c9a96e'},{id:'personal',label:'Personal',color:'#6e9ec9'},{id:'cat_1779216213490',label:'Marketing',color:'#9b8fd6'},{id:'cat_1779216216367',label:'Web',color:'#5dcaa5'},{id:'cat_1779216282983',label:'B2B',color:'#e09f66'},{id:'cat_1779216393625',label:'Tienda',color:'#a0c878'}];
if(!data.people) data.people=[{id:'p_1779214823103',name:'Nano'},{id:'p_1779214829839',name:'Ali'},{id:'p_1779214833874',name:'Omar'}];
if(!data.notes)data.notes={int:'',free:''};
if(data.mood==null)data.mood=2;

let activeFilter='all', activeCat='all';
const getCat=id=>data.cats.find(c=>c.id===id)||{label:'—',color:'#555'};
const getPerson=id=>data.people.find(p=>p.id===id)||null;
const initials=n=>n.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
const escHtml=s=>s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

function renderCats(){
  const list=document.getElementById('cat-list');
  list.innerHTML='';
  const all=document.createElement('div');
  all.className='cat-item'+(activeCat==='all'?' active':'');
  all.innerHTML=`<span class="cat-dot" style="background:#555"></span><span>Todas</span><span class="cat-count">${data.tasks.length}</span>`;
  all.onclick=()=>{activeCat='all';render();};
  list.appendChild(all);
  data.cats.forEach(cat=>{
    const count=data.tasks.filter(t=>t.cat===cat.id).length;
    const el=document.createElement('div');
    el.className='cat-item'+(activeCat===cat.id?' active':'');
    el.innerHTML=`<span class="cat-dot" style="background:${cat.color}"></span><span style="flex:1">${cat.label}</span><span class="cat-count">${count}</span>`;
    el.onclick=()=>{activeCat=cat.id;render();};
    el.oncontextmenu=e=>{e.preventDefault();showCatMenu(e,cat);};
    list.appendChild(el);
  });
  const ac=document.getElementById('add-cat');
  ac.innerHTML=data.cats.map(c=>`<option value="${c.id}">${c.label}</option>`).join('');
}

function renderPeople(){
  const list=document.getElementById('people-list');
  list.innerHTML='';
  if(!data.people.length){list.innerHTML='<div style="padding:4px 16px;font-size:11px;color:var(--muted)">Sin personas aún</div>';}
  else{data.people.forEach(p=>{const el=document.createElement('div');el.className='person-item';el.innerHTML=`<div class="p-avatar">${initials(p.name)}</div><span>${p.name}</span>`;el.oncontextmenu=e=>{e.preventDefault();showPersonMenu(e,p);};list.appendChild(el);});}
  const ao=document.getElementById('add-owner');
  ao.innerHTML='<option value="">Sin responsable</option>'+data.people.map(p=>`<option value="${p.id}">${p.name}</option>`).join('');
}

function addCategory(){
  const name=prompt('Nombre de la categoría:');
  if(!name||!name.trim())return;
  const cols=['#c96e6e','#6e9ec9','#9b8fd6','#5dcaa5','#e09f66','#a0c878'];
  data.cats.push({id:'cat_'+Date.now(),label:name.trim(),color:cols[data.cats.length%cols.length]});
  saveCats();render();
}
function addPerson(){
  const name=prompt('Nombre de la persona:');
  if(!name||!name.trim())return;
  data.people.push({id:'p_'+Date.now(),name:name.trim()});
  savePpl();render();
}

function showCatMenu(e,cat){
  removeCtx();
  const m=document.createElement('div');m.className='ctx-menu';m.id='ctx-menu';
  m.style.left=e.clientX+'px';m.style.top=e.clientY+'px';
  m.innerHTML=`<div class="ctx-item" onclick="renameCat('${cat.id}')">Renombrar</div><div class="ctx-sep"></div><div class="ctx-item" style="color:var(--p1)" onclick="deleteCat('${cat.id}')">Eliminar</div>`;
  document.body.appendChild(m);
  setTimeout(()=>document.addEventListener('click',removeCtx,{once:true}),10);
}
function showPersonMenu(e,p){
  removeCtx();
  const m=document.createElement('div');m.className='ctx-menu';m.id='ctx-menu';
  m.style.left=e.clientX+'px';m.style.top=e.clientY+'px';
  m.innerHTML=`<div class="ctx-item" onclick="renamePerson('${p.id}')">Renombrar</div><div class="ctx-sep"></div><div class="ctx-item" style="color:var(--p1)" onclick="deletePerson('${p.id}')">Eliminar</div>`;
  document.body.appendChild(m);
  setTimeout(()=>document.addEventListener('click',removeCtx,{once:true}),10);
}
function renameCat(id){removeCtx();const c=data.cats.find(x=>x.id===id);const n=prompt('Nuevo nombre:',c.label);if(n&&n.trim()){c.label=n.trim();saveCats();render();}}
function deleteCat(id){removeCtx();if(!confirm('¿Eliminar categoría?'))return;data.cats=data.cats.filter(c=>c.id!==id);data.tasks.forEach(t=>{if(t.cat===id)t.cat=data.cats[0]?.id||'';});if(activeCat===id)activeCat='all';saveCats();save();render();}
function renamePerson(id){removeCtx();const p=data.people.find(x=>x.id===id);const n=prompt('Nuevo nombre:',p.name);if(n&&n.trim()){p.name=n.trim();savePpl();render();}}
function deletePerson(id){removeCtx();if(!confirm('¿Eliminar persona?'))return;data.people=data.people.filter(p=>p.id!==id);data.tasks.forEach(t=>{if(t.owner===id)t.owner='';});savePpl();save();render();}
function removeCtx(){const m=document.getElementById('ctx-menu');if(m)m.remove();}

function filteredTasks(){
  return data.tasks.filter(t=>{
    if(activeCat!=='all'&&t.cat!==activeCat)return false;
    if(activeFilter==='pending'&&t.done)return false;
    if(activeFilter==='done'&&!t.done)return false;
    return true;
  });
}

function renderTasks(){
  const area=document.getElementById('task-area');
  area.innerHTML='';
  document.getElementById('main-title').textContent=activeCat==='all'?'Todas las tareas':getCat(activeCat).label;
  const tasks=filteredTasks();
  PRIOS.forEach(p=>{
    const group=tasks.filter(t=>t.prio===p.id);
    if(!group.length)return;
    const sec=document.createElement('div');
    sec.className='priority-group';
    sec.innerHTML=`<div class="priority-label" onclick="toggleGroup(this.parentElement)"><span class="p-dot ${p.dot}"></span>${p.label}<span class="group-toggle">▾</span></div><div class="group-tasks"></div>`;
    const gt=sec.querySelector('.group-tasks');
    group.forEach(t=>gt.appendChild(makeTaskEl(t)));
    area.appendChild(sec);
  });
  updateProgress();
}

function makeTaskEl(t){
  const cat=getCat(t.cat);
  const p=PRIOS.find(x=>x.id===t.prio)||PRIOS[1];
  const person=getPerson(t.owner);
  const el=document.createElement('div');
  el.className='task-item'+(t.done?' done':'');
  el.dataset.id=t.id;
  const prioOpts=PRIOS.map(px=>`<option value="${px.id}"${px.id===t.prio?' selected':''}>${px.label}</option>`).join('');
  const catOpts=data.cats.map(c=>`<option value="${c.id}"${c.id===t.cat?' selected':''}>${c.label}</option>`).join('');
  const ownerOpts='<option value="">— Nadie</option>'+data.people.map(px=>`<option value="${px.id}"${px.id===t.owner?' selected':''}>${px.name}</option>`).join('');
  const ownerBg=person?'var(--accent2)':'rgba(255,255,255,0.04)';
  const ownerColor=person?'var(--accent)':'var(--muted)';
  el.innerHTML=`
    <div class="task-check" onclick="toggleTask(${t.id})">
      <svg class="chk" width="8" height="6" viewBox="0 0 8 6" fill="none"><path d="M1 3L3 5L7 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="task-text" onclick="editText(${t.id},this)">${escHtml(t.text)}</div>
    <select class="task-sel" style="background:${p.bg};color:${p.tc}" onchange="setPrio(${t.id},parseInt(this.value))" onclick="event.stopPropagation()">${prioOpts}</select>
    <select class="task-sel" style="background:${cat.color}22;color:${cat.color}" onchange="setCat(${t.id},this.value)" onclick="event.stopPropagation()">${catOpts}</select>
    <select class="task-sel" style="background:${ownerBg};color:${ownerColor}" onchange="setOwner(${t.id},this.value)" onclick="event.stopPropagation()">${ownerOpts}</select>
    <button class="task-delete" onclick="deleteTask(${t.id})">✕</button>`;
  el.oncontextmenu=e=>{e.preventDefault();showTaskMenu(e,t);};
  return el;
}

function toggleGroup(sec){sec.classList.toggle('collapsed');}
function toggleTask(id){const t=data.tasks.find(x=>x.id===id);if(t){t.done=!t.done;save();render();}}
function deleteTask(id){data.tasks=data.tasks.filter(x=>x.id!==id);save();render();}
function setPrio(id,prio){removeCtx();const t=data.tasks.find(x=>x.id===id);if(t){t.prio=prio;save();render();}}
function setCat(id,cat){removeCtx();const t=data.tasks.find(x=>x.id===id);if(t){t.cat=cat;save();render();}}
function setOwner(id,owner){const t=data.tasks.find(x=>x.id===id);if(t){t.owner=owner;save();render();}}

function editText(id,el){
  const t=data.tasks.find(x=>x.id===id);
  if(!t||t.done)return;
  const inp=document.createElement('input');
  inp.className='task-text-input';inp.value=t.text;
  el.replaceWith(inp);inp.focus();inp.select();
  function commit(){const v=inp.value.trim();if(v){t.text=v;save();}render();}
  inp.addEventListener('blur',commit);
  inp.addEventListener('keydown',e=>{if(e.key==='Enter')inp.blur();if(e.key==='Escape')render();});
}

function showTaskMenu(e,t){
  removeCtx();
  const m=document.createElement('div');m.className='ctx-menu';m.id='ctx-menu';
  m.style.left=e.clientX+'px';m.style.top=e.clientY+'px';
  const pI=PRIOS.map(p=>`<div class="ctx-item" onclick="setPrio(${t.id},${p.id})"><span class="p-dot ${p.dot}" style="background:${p.color}"></span>${p.label}${t.prio===p.id?' ✓':''}</div>`).join('');
  const cI=data.cats.map(c=>`<div class="ctx-item" onclick="setCat(${t.id},'${c.id}')"><span class="cat-dot" style="background:${c.color}"></span>${c.label}${t.cat===c.id?' ✓':''}</div>`).join('');
  const oI=[`<div class="ctx-item" onclick="setOwner(${t.id},'');removeCtx()">— Sin responsable${!t.owner?' ✓':''}</div>`,...data.people.map(p=>`<div class="ctx-item" onclick="setOwner(${t.id},'${p.id}');removeCtx()">${p.name}${t.owner===p.id?' ✓':''}</div>`)].join('');
  m.innerHTML=`<div class="ctx-head">Prioridad</div>${pI}<div class="ctx-sep"></div><div class="ctx-head">Categoría</div>${cI}<div class="ctx-sep"></div><div class="ctx-head">Responsable</div>${oI}<div class="ctx-sep"></div><div class="ctx-item" style="color:var(--p1)" onclick="deleteTask(${t.id});removeCtx()">Eliminar</div>`;
  document.body.appendChild(m);
  setTimeout(()=>document.addEventListener('click',removeCtx,{once:true}),10);
}

function updateProgress(){
  const v=filteredTasks();
  const done=v.filter(t=>t.done).length,total=v.length;
  document.getElementById('prog-txt').textContent=`${done} / ${total}`;
  document.getElementById('pfill').style.width=total?`${Math.round(done/total*100)}%`:'0%';
}

document.getElementById('add-input').addEventListener('keydown',function(e){
  if(e.key!=='Enter'||!this.value.trim())return;
  const prio=parseInt(document.getElementById('add-prio').value);
  const cat=document.getElementById('add-cat').value||(data.cats[0]?.id||'');
  const owner=document.getElementById('add-owner').value||'';
  data.tasks.push({id:Date.now(),text:this.value.trim(),done:false,prio,cat,owner});
  this.value='';save();render();
});

function setFilter(f,btn){
  activeFilter=f;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');render();
}

const ni=document.getElementById('note-int'),nf=document.getElementById('note-free');
ni.value=data.notes.int;nf.value=data.notes.free;
ni.addEventListener('input',()=>{data.notes.int=ni.value;save();});
nf.addEventListener('input',()=>{data.notes.free=nf.value;save();});

function setMood(btn){
  document.querySelectorAll('.mood-btn').forEach((b,i)=>{b.classList.remove('active');if(b===btn)data.mood=i;});
  btn.classList.add('active');save();
}
document.querySelectorAll('.mood-btn').forEach((b,i)=>{if(i===data.mood)b.classList.add('active');else b.classList.remove('active');});

function exportExcel(){
  const headers=['Tarea','Estado','Prioridad','Categoría','Responsable'];
  const rows=data.tasks.map(t=>[
    t.text,
    t.done?'Completada':'Pendiente',
    PRIOS.find(p=>p.id===t.prio)?.label||'',
    getCat(t.cat)?.label||'',
    getPerson(t.owner)?.name||''
  ]);
  const esc=v=>`"${String(v).replace(/"/g,'""')}"`;
  const csv=[headers,...rows].map(r=>r.map(esc).join(',')).join('\r\n');
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;a.download=`tareas_${now.toISOString().slice(0,10)}.csv`;
  a.click();URL.revokeObjectURL(url);
}

function render(){renderCats();renderPeople();renderTasks();}
render();
</script>


</body></html>
